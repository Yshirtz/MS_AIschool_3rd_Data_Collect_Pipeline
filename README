## 📂 프로젝트 구조 (Project Structure)
```text
├── pipeline.py          # 메인 파이프라인 스크립트 (3-Thread 오케스트레이션) [cite: 12]
├── tasks/
│   ├── data_fetcher.py  # 네이버 API 데이터 수집 및 브랜드 필터링 [cite: 12]
│   ├── ai_processor.py  # AI 모델 추론(YOLO/SAM/OCR) 및 임베딩 [cite: 12]
│   └── db_handler.py    # Vector DB 데이터 매핑 및 Batch Insert [cite: 12]
├── azure_scripts/       # Azure ML 인프라 구축 및 스케줄링 스크립트 [cite: 13]
├── config.py            # 모델 경로 및 환경 변수 중앙 관리 [cite: 12]
└── models.py            # ResNet50 기반 커스텀 임베딩 모델 정의
